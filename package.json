{
	"name": "e-invoice-eu",
	"private": true,
	"description": "Free and open source Node.js/TypeScript tools for generating EN16931-compliant electronic invoices (UBL, CII, Factur-X/ZUGFeRD, XRechnung) in Europe.",
	"homepage": "https://gflohr.github.io/e-invoice-eu",
	"keywords": [
		"e-invoice",
		"electronic-invoice",
		"UBL",
		"CII",
		"Factur-X",
		"ZUGFeRD",
		"XRechnung",
		"e-invoicing",
		"EU e-invoice",
		"nodejs",
		"typescript"
	],
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "pnpm -r --workspace-concurrency=3 run build",
		"format": "prettier --write *.mjs *.json *.md && pnpm -r --parallel run format",
		"start": "pnpm -r --filter=@e-invoice-eu/server run start",
		"start:dev": "pnpm -r --filter=@e-invoice-eu/server run start:dev",
		"start:debug": "pnpm -r --filter=@e-invoice-eu/server run start:debug",
		"start:prod": "pnpm -r --filter=@e-invoice-eu/server run start:prod",
		"build:typedoc": "pnpm --filter=@e-invoice-eu/core run typedoc",
		"lint": "pnpm -r --parallel run lint",
		"lint:fix": "pnpm -r --parallel run lint:fix",
		"lint:staged": "pnpm -r --parallel run lint:staged",
		"test": "pnpm -r --parallel run test",
		"test:changed": "pnpm -r --parallel run test:changed",
		"test:cov": "pnpm -r --parallel run test:cov",
		"test:cov-changed": "pnpm -r --parallel run test:cov-changed",
		"release": "HUSKY=0 pnpm changeset publish",
		"prerelease": "pnpm install && pnpm run build && pnpm run test",
		"check:clean": "./check-clean && pnpm -r --parallel run check:clean",
		"prepublish": "pnpm run check:clean && pnpm run test",
		"clean": "pnpm -r --parallel run clean",
		"prepare": "husky",
		"preinstall": "npx only-allow pnpm"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@esgettext/tools": "^1.3.10",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"eslint-plugin-import": "^2.32.0",
		"glob": "^13.0.6",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"js-yaml": "^4.1.1",
		"pnpm": "^10.33.0",
		"prettier": "^3.8.1"
	},
	"dependencies": {
		"dev": "^0.1.3"
	}
}
